							- const image = note.image || note.cover || note.hero || note.thumbnail || ""
							- const hasImage = Boolean(image)
							- const noteId = `note-${index}`
							- const noteTags = (note.tags || []).join('|')
							- const noteExcerpt = stripExcerptMath(note.excerpt || '')
							- const readTime = Math.max(3, Math.ceil((noteExcerpt || note.title || '').length / 120))
							article.note-card-shell(data-note-shell)
								a.post-card.note-card(class=!hasImage ? "no-image" : null href=`#${noteId}` data-note-card data-note-open data-note-id=`${noteId}` data-note-key=`${note.url}` data-note-index=`${index}` data-note-url=`${note.url}` data-note-image=`${image}` data-note-archived=(note.archived || note.archive) ? "true" : "false" data-comment-term=`note:${note.url}` data-title=`${note.title}` data-tags=`${noteTags}` data-category=`${note.category || ''}` data-date=`${note.date || ''}` data-excerpt=`${noteExcerpt}` data-read-time=`${readTime}` style=hasImage ? `--card-image: url("${image}")` : null)
