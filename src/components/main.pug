- const hp = homepage || {}
- const stats = hp.stats || {}
- const notes = hp.notes || []
- const memos = hp.memos || []
- const resources = hp.resources || []
- const paperData = hp.papers || {}
- const paperItems = paperData.items || []
- const paperTopics = paperData.topics || []
- const importedAt = hp.imported_at || ''
- const categories = hp.categories || []
- const navItems = [main.ul.first, main.ul.second, main.ul.third, main.ul.fourth].filter(Boolean)
- const isExternal = href => /^(https?:|mailto:)/.test(href || '')

.content.content-main
	canvas.grid-background#gridCanvas
	.site-shell
		button.theme-toggle(type="button" aria-label="Switch to light mode" data-theme-toggle)
			span.theme-toggle-icon(data-theme-icon) ☀
		#card
			.card-inner.fade
				header.profile-header
					img(src=`${main.avatar.link}` width=`${main.avatar.width}` height=`${main.avatar.height}` alt="Junle Chen avatar")
					p.profile-eyebrow Imported research workspace
					h1(data-translate="name") #{main.name}
					h2#signature(data-translate="signature" original-content=`${main.signature}`) #{main.signature}

				.stats-strip(aria-label="Imported content summary")
					.stat-item
						strong #{stats.notes || 0}
						span Notes
					.stat-item
						strong #{stats.memos || 0}
						span Memos
					.stat-item
						strong #{stats.resources || 0}
						span Resources
					.stat-item
						strong #{stats.assets || 0}
						span Assets

				ul.primary-links
					each item in navItems
						li
							a(href=`${item.href}` aria-label=`${item.text}` target=isExternal(item.href) ? "_blank" : null rel=isExternal(item.href) ? "noopener noreferrer" : null)
								i(class=`icon icon-${item.icon}`)
								span(data-translate=`${item.text}`) #{item.text}

				.hero-actions
					a.action-button.primary(href="#notes") Browse Notes
					a.action-button(href="#resources") Open Resources
					a.action-button(href="assets/content/pages/aboutme.md") About Source

		section.content-section#notes
			.section-heading
				p.section-eyebrow Notes archive
				h2 Notes migrated from junle-cc-website
				p
					| #{stats.notes || notes.length || 0} Markdown notes are copied into
					code  assets/content/notes
					| . The latest entries are shown here with raw Markdown links for the preserved source files.
			.section-tools
				label.search-box(for="noteSearch")
					span Search notes
					input#noteSearch(type="search" placeholder="motion, pyenv, LLM, benchmark..." autocomplete="off")
				if categories.length
					.category-strip(aria-label="Note categories")
						each category in categories
							span #{category}
			.card-grid.note-grid
				each note in notes.slice(0, 12)
					article.content-card.note-card(data-note-card data-title=`${note.title}` data-tags=`${(note.tags || []).join(' ')}` data-excerpt=`${note.excerpt}`)
						.card-meta
							span #{note.date || "Undated"}
							span #{note.category || "Note"}
						h3
							a(href=`${note.url}` target="_blank" rel="noopener noreferrer") #{note.title}
						if note.excerpt
							p #{note.excerpt}
						if note.tags && note.tags.length
							.tag-row
								each tag in note.tags.slice(0, 3)
									span #{tag}
			p.empty-state#noteEmptyState(hidden) No matching notes.
			.archive-link
				a(href="assets/content/homepage-content.json" target="_blank" rel="noopener noreferrer") Open content manifest

		section.content-section#memos
			.section-heading
				p.section-eyebrow Memos
				h2 Quick public memo stream
				p
					| Public memo YAML from the old site is preserved in
					code  assets/content/data/memos.yml
					|  and surfaced here as compact cards.
			.card-grid.memo-grid
				each memo in memos.slice(0, 8)
					article.content-card.memo-card(data-memo-card data-title=`${memo.title}` data-content=`${memo.content}` data-category=`${memo.category}`)
						.card-meta
							span #{memo.date || "No date"}
							span #{memo.priority || "normal"}
						h3 #{memo.title}
						if memo.content
							p #{memo.content}
						else
							p.muted Empty memo body in source data.
						.tag-row
							span #{memo.category || "general"}
							if memo.completed
								span done
							else
								span open

		section.content-section#papers
			.section-heading
				p.section-eyebrow Paper radar
				h2 Agent-planning paper tracking data
				p
					| The Paper Radar JSON was copied from the old site and is ready for future Zotero or arXiv updates.
					if paperData.updated_at
						|  Last data date: #{paperData.updated_at}.
			if paperTopics.length
				.topic-strip
					each topic in paperTopics
						span #{topic}
				if paperItems.length
					.card-grid.paper-grid
						each paper in paperItems.slice(0, 6)
							article.content-card.paper-card
								.card-meta
									span #{paper.date || paper.published || "No date"}
									span #{paper.source || "paper"}
								h3
									if paper.url
										a(href=`${paper.url}` target="_blank" rel="noopener noreferrer") #{paper.title}
									else
										| #{paper.title}
								if paper.summary
									p #{paper.summary}
				else
					p.empty-state Paper data is present, but no active paper items are currently listed in the copied JSON.

		section.content-section#resources
			.section-heading
				p.section-eyebrow Resources
				h2 Preserved links and workflow files
				p
					| Old-site resources, docs, data files, and scripts are available as static assets. Imported #{importedAt || "from local source"}.
			.resource-list
				each resource in resources
					a.resource-item(href=`${resource.href}` target=isExternal(resource.href) ? "_blank" : null rel=isExternal(resource.href) ? "noopener noreferrer" : null)
						span.resource-type #{resource.type}
						strong #{resource.title}
						span #{resource.description}
			.source-note
				span Source archive:
				a(href="assets/content/data/papers.json" target="_blank" rel="noopener noreferrer") papers.json
				a(href="assets/content/data/paper_topics.json" target="_blank" rel="noopener noreferrer") paper_topics.json
				a(href="assets/content/scripts/update_papers.py" target="_blank" rel="noopener noreferrer") update_papers.py
